{
	"name": "@c15t/vitest-config",
	"version": "1.0.0",
	"type": "module",
	"exports": {
		"./base": {
			"types": "./src/base-config.ts",
			"import": "./src/base-config.ts"
		},
		"./ui": {
			"types": "./src/ui-config.ts",
			"import": "./src/ui-config.ts"
		}
	},
	"private": true,
	"scripts": {
		"check-types": "tsc --noEmit",
		"dev": "echo '@c15t/vitest-config has no watch task'",
		"lint": "bun biome lint ./src",
		"fmt": "bun biome format --write . && bun biome check --formatter-enabled=false --linter-enabled=false --write"
	},
	"devDependencies": {
		"@c15t/typescript-config": "workspace:*",
		"@vitest/ui": "4.1.2",
		"jsdom": "^29.0.1"
	}
}
