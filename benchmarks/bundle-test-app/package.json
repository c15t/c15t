{
	"name": "@c15t/next-bundle-bench",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"analyze": "ANALYZE=true next build",
		"analyze:json": "bun analyze-bundle.ts --json",
		"analyze:md": "bun analyze-bundle.ts --markdown",
		"bench": "BENCH_OUTPUT_DIR=../../.benchmarks/current/bundle bun analyze-bundle.ts",
		"bench:ci": "BENCH_OUTPUT_DIR=../../.benchmarks/head/bundle bun analyze-bundle.ts",
		"bench:nightly": "BENCH_OUTPUT_DIR=../../.benchmarks/nightly/bundle bun analyze-bundle.ts"
	},
	"dependencies": {
		"@c15t/benchmarking": "workspace:*",
		"next": "16.1.6",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"c15t": "workspace:*",
		"@c15t/react": "workspace:*",
		"@c15t/nextjs": "workspace:*"
	},
	"devDependencies": {
		"@next/bundle-analyzer": "16.1.6",
		"typescript": "5.8.3",
		"@types/react": "19.2.3",
		"@types/node": "22.14.1"
	}
}
