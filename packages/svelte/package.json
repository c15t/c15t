{
	"name": "@c15t/svelte",
	"version": "2.0.0-rc.4",
	"description": "Developer-first CMP for Svelte: cookie banner, consent manager, preferences centre. GDPR ready with minimal setup and rich customization",
	"keywords": [
		"svelte",
		"sveltekit",
		"consent",
		"privacy",
		"gdpr",
		"ccpa",
		"lgpd",
		"headless",
		"typescript",
		"cookie-banner",
		"consent-management-platform",
		"cmp",
		"consent-banner",
		"user-consent",
		"privacy-compliance",
		"web-privacy"
	],
	"homepage": "https://c15t.com/docs/frameworks/svelte/quickstart",
	"repository": {
		"type": "git",
		"url": "https://github.com/c15t/c15t.git",
		"directory": "packages/svelte"
	},
	"license": "GPL-3.0-only",
	"sideEffects": false,
	"type": "module",
	"exports": {
		"./headless": {
			"types": "./dist/headless.d.ts",
			"svelte": "./dist/headless.js",
			"default": "./dist/headless.js"
		},
		"./server": {
			"types": "./dist/server/index.d.ts",
			"import": "./dist/server/index.js",
			"default": "./dist/server/index.js"
		},
		"./vite": {
			"types": "./dist/vite-plugin.d.ts",
			"import": "./dist/vite-plugin.js",
			"default": "./dist/vite-plugin.js"
		},
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"prebuild": "genversion --esm --semi src/version.ts",
		"build": "bun prebuild && svelte-package -i src -o dist",
		"check-types": "bun prebuild && svelte-check --tsconfig ./tsconfig.json",
		"dev": "bun prebuild && svelte-package -i src -o dist --watch",
		"fmt": "bun biome format --write . && bun biome check --formatter-enabled=false --linter-enabled=false --write",
		"lint": "bun biome lint ./src",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@ark-ui/svelte": "^5.19.0",
		"@c15t/ui": "workspace:*",
		"c15t": "workspace:*",
		"clsx": "2.1.1"
	},
	"devDependencies": {
		"@c15t/typescript-config": "workspace:*",
		"@c15t/vitest-config": "workspace:*",
		"@sveltejs/package": "^2.3.7",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@testing-library/jest-dom": "^6.0.0",
		"@testing-library/svelte": "^5.0.0",
		"genversion": "3.2.0",
		"jsdom": "^25.0.0",
		"svelte-check": "^4.1.5",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"vite": "^5.0.0 || ^6.0.0"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	}
}
