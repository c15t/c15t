{
	"$schema": "https://unpkg.com/knip@latest/schema.json",
	"entry": [
		"./src/lib/index.ts",
		"./src/lib/headless.ts",
		"./src/lib/types.ts",
		"./src/lib/utils.ts",
		"./src/lib/context.svelte.ts"
	],
	"ignoreBinaries": [
		"biome",
		"svelte-package",
		"svelte-check",
		"tsc",
		"vitest"
	],
	"ignore": ["**/*.spec.{js,ts}", "**/*.test.{js,ts}", "**/__tests__/**"],
	"ignoreDependencies": ["@c15t/typescript-config", "c15t"],
	"rules": {
		"exports": "warn",
		"types": "warn",
		"dependencies": "error",
		"files": "warn"
	},
	"ignoreExportsUsedInFile": true
}
