{
	"name": "c15t",
	"version": "2.0.0",
	"description": "Developer-first CMP for JavaScript: cookie banner, consent manager, preferences centre. GDPR ready with minimal setup and rich customization",
	"keywords": [
		"nextjs",
		"consent",
		"privacy",
		"gdpr",
		"ccpa",
		"lgpd",
		"server-side rendering",
		"react",
		"typescript",
		"cookie-banner",
		"consent-management-platform",
		"cmp",
		"consent-banner",
		"user-consent",
		"privacy-compliance",
		"web-privacy"
	],
	"homepage": "https://c15t.com/docs/frameworks/javascript/quickstart",
	"repository": {
		"type": "git",
		"url": "https://github.com/c15t/c15t.git",
		"directory": "packages/core"
	},
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist-types/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./v3": {
			"types": "./dist-types/v3/index.d.ts",
			"import": "./dist/v3.js",
			"require": "./dist/v3.cjs"
		},
		"./v3/modules/script-loader": {
			"types": "./dist-types/v3/modules/script-loader/index.d.ts",
			"import": "./dist/v3-script-loader.js",
			"require": "./dist/v3-script-loader.cjs"
		},
		"./v3/modules/network-blocker": {
			"types": "./dist-types/v3/modules/network-blocker/index.d.ts",
			"import": "./dist/v3-network-blocker.js",
			"require": "./dist/v3-network-blocker.cjs"
		},
		"./v3/modules/iframe-blocker": {
			"types": "./dist-types/v3/modules/iframe-blocker/index.d.ts",
			"import": "./dist/v3-iframe-blocker.js",
			"require": "./dist/v3-iframe-blocker.cjs"
		},
		"./v3/modules/persistence": {
			"types": "./dist-types/v3/modules/persistence/index.d.ts",
			"import": "./dist/v3-persistence.js",
			"require": "./dist/v3-persistence.cjs"
		}
	},
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "./dist-types/index.d.ts",
	"files": [
		"dist",
		"dist-types",
		"docs",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"prebuild": "genversion --esm --semi src/version.ts",
		"build": "bun prebuild && rslib build && bun ../../scripts/normalize-dist-types.mjs && bun ../../scripts/agent-docs/generate-package-docs.ts c15t",
		"build:agent-docs": "bun ../../scripts/agent-docs/generate-package-docs.ts c15t",
		"check-types": "bun prebuild && tsc --noEmit",
		"check-types:test": "tsc -p tsconfig.test.json",
		"dev": "sh -c 'bun prebuild && rslib build --no-dts --no-clean && rslib build --watch --no-dts --no-clean'",
		"fmt": "bun biome format --write . && bun biome check --formatter-enabled=false --linter-enabled=false --write",
		"lint": "bun biome lint ./src",
		"prepack": "bun run build",
		"test": "bun prebuild && vitest run",
		"test:watch": "bun prebuild && vitest"
	},
	"browserslist": [
		">0.2%",
		"not dead",
		"not op_mini all"
	],
	"dependencies": {
		"@c15t/schema": "workspace:*",
		"@c15t/translations": "workspace:*",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@c15t/typescript-config": "workspace:*",
		"@c15t/vitest-config": "workspace:*",
		"genversion": "3.2.0",
		"vitest-localstorage-mock": "0.1.2"
	},
	"publishConfig": {
		"access": "public"
	}
}
