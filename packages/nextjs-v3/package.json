{
	"name": "@c15t/nextjs-v3",
	"version": "2.0.0",
	"description": "Temporary v3 Next.js package for c15t.",
	"keywords": [
		"nextjs",
		"react",
		"consent",
		"privacy",
		"v3"
	],
	"homepage": "https://c15t.com/docs/frameworks/next/quickstart",
	"repository": {
		"type": "git",
		"url": "https://github.com/c15t/c15t.git",
		"directory": "packages/nextjs-v3"
	},
	"license": "Apache-2.0",
	"sideEffects": [
		"**/*.css"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist-types/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./server": {
			"types": "./dist-types/server.d.ts",
			"import": "./dist/server.js",
			"require": "./dist/server.cjs"
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist-types/index.d.ts",
	"files": [
		"dist",
		"dist-types"
	],
	"scripts": {
		"prebuild": "genversion --esm --semi src/version.ts",
		"build": "bun prebuild && rslib build && bun ../../scripts/normalize-dist-types.mjs",
		"check-types": "bun prebuild && tsc --noEmit",
		"dev": "sh -c 'bun prebuild && rslib build --no-dts --no-clean && rslib build --watch --no-dts --no-clean'",
		"fmt": "bun biome format --write . && bun biome check --formatter-enabled=false --linter-enabled=false --write",
		"lint": "bun biome lint ./src",
		"prepack": "bun run build",
		"test": "bun prebuild && vitest run --passWithNoTests",
		"test:watch": "bun prebuild && vitest --passWithNoTests"
	},
	"dependencies": {
		"@c15t/react-v3": "workspace:*",
		"@c15t/translations": "workspace:*",
		"c15t-v3": "workspace:*",
		"c15t": "workspace:*"
	},
	"devDependencies": {
		"@c15t/typescript-config": "workspace:*",
		"@c15t/vitest-config": "workspace:*",
		"genversion": "3.2.0",
		"typescript": "6.0.2"
	},
	"peerDependencies": {
		"next": "^16.0.0 || ^15.0.0 || ^14.0.0 || ^13.0.0",
		"react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc",
		"react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0 || ^19.0.0-rc"
	},
	"publishConfig": {
		"access": "public"
	}
}
