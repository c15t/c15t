{
	"name": "@c15t/scripts",
	"version": "2.0.1",
	"description": "Pre-built scripts of popular tools for c15t's script loader — GTM, Google Tag (GA4 + Ads), Meta Pixel, PostHog, TikTok Pixel, LinkedIn Insights, Microsoft UET, X Pixel.",
	"keywords": [
		"c15t",
		"script-loader",
		"consent",
		"gdpr",
		"ccpa",
		"lgpd",
		"gtm",
		"google-tag-manager",
		"google-tag",
		"ga4",
		"google-ads",
		"meta-pixel",
		"posthog",
		"tiktok-pixel",
		"linkedin-insights",
		"microsoft-uet",
		"x-pixel",
		"analytics-consent",
		"consent-mode",
		"privacy",
		"cmp"
	],
	"homepage": "https://c15t.com/docs/frameworks/javascript/script-loader",
	"bugs": {
		"url": "https://github.com/c15t/c15t/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/c15t/c15t.git",
		"directory": "packages/scripts"
	},
	"license": "Apache-2.0",
	"sideEffects": false,
	"type": "module",
	"exports": {
		"./*": {
			"types": "./dist-types/*.d.ts",
			"import": "./dist/*.js",
			"require": "./dist/*.cjs"
		}
	},
	"files": [
		"dist",
		"dist-types"
	],
	"scripts": {
		"build": "rslib build && bun ../../scripts/normalize-dist-types.mjs",
		"check-types": "tsc --noEmit",
		"dev": "sh -c 'rslib build --no-dts --no-clean && rslib build --watch --no-dts --no-clean'",
		"fmt": "bun biome format --write . && bun biome check --formatter-enabled=false --linter-enabled=false --write",
		"lint": "bun biome lint ./src",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest"
	},
	"browserslist": [
		">0.2%",
		"not dead",
		"not op_mini all"
	],
	"devDependencies": {
		"@c15t/typescript-config": "workspace:*",
		"@c15t/vitest-config": "workspace:*",
		"c15t": "workspace:*"
	},
	"publishConfig": {
		"access": "public"
	}
}
