{
	"name": "@c15t/embed",
	"version": "0.0.1",
	"private": true,
	"description": "Standalone embed script for c15t consent management on CMS platforms.",
	"type": "module",
	"scripts": {
		"build": "bun build.ts && bun src/ui/strip-layers.ts",
		"check-types": "tsc --noEmit",
		"dev": "bun build.ts --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@c15t/ui": "workspace:*",
		"c15t": "workspace:*"
	},
	"devDependencies": {
		"@c15t/typescript-config": "workspace:*",
		"@c15t/vitest-config": "workspace:*",
		"@vitest/browser-playwright": "latest",
		"esbuild": "^0.28.0",
		"vitest": "latest"
	}
}
