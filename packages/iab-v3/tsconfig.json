{
	"extends": "@c15t/typescript-config/react-library.json",
	"compilerOptions": {
		"rootDir": "src",
		"lib": ["dom", "esnext"],
		"paths": {
			"c15t": ["../core/dist-types/index.d.ts"],
			"c15t/*": ["../core/dist-types/*"],
			"c15t-v3": ["../core-v3/dist-types/index.d.ts"],
			"c15t-v3/*": ["../core-v3/dist-types/*"],
			"@c15t/schema": ["../schema/dist-types/index.d.ts"],
			"@c15t/schema/*": ["../schema/dist-types/*"]
		}
	},
	"include": ["src"],
	"exclude": [
		"node_modules",
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.spec.ts",
		"**/*.spec.tsx"
	]
}
