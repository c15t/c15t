{
	"name": "@c15t/react-v3",
	"version": "2.0.0",
	"description": "Temporary v3 React package for c15t.",
	"keywords": [
		"react",
		"consent",
		"privacy",
		"gdpr",
		"v3"
	],
	"homepage": "https://c15t.com/docs/frameworks/react/quickstart",
	"repository": {
		"type": "git",
		"url": "https://github.com/c15t/c15t.git",
		"directory": "packages/react-v3"
	},
	"license": "Apache-2.0",
	"sideEffects": [
		"**/*.css"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist-types/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./provider": {
			"types": "./dist-types/provider.d.ts",
			"import": "./dist/provider.js",
			"require": "./dist/provider.cjs"
		},
		"./hooks": {
			"types": "./dist-types/v3/hooks.d.ts",
			"import": "./dist/v3/hooks.js",
			"require": "./dist/v3/hooks.cjs"
		},
		"./draft": {
			"types": "./dist-types/draft.d.ts",
			"import": "./dist/draft.js",
			"require": "./dist/draft.cjs"
		},
		"./module-hooks": {
			"types": "./dist-types/module-hooks.d.ts",
			"import": "./dist/module-hooks.js",
			"require": "./dist/module-hooks.cjs"
		},
		"./module-hooks/script-loader": {
			"types": "./dist-types/module-hooks/script-loader.d.ts",
			"import": "./dist/module-hooks/script-loader.js",
			"require": "./dist/module-hooks/script-loader.cjs"
		},
		"./module-hooks/persistence": {
			"types": "./dist-types/module-hooks/persistence.d.ts",
			"import": "./dist/module-hooks/persistence.js",
			"require": "./dist/module-hooks/persistence.cjs"
		},
		"./module-hooks/network-blocker": {
			"types": "./dist-types/module-hooks/network-blocker.d.ts",
			"import": "./dist/module-hooks/network-blocker.js",
			"require": "./dist/module-hooks/network-blocker.cjs"
		},
		"./module-hooks/iframe-blocker": {
			"types": "./dist-types/module-hooks/iframe-blocker.d.ts",
			"import": "./dist/module-hooks/iframe-blocker.js",
			"require": "./dist/module-hooks/iframe-blocker.cjs"
		},
		"./consent-banner": {
			"types": "./dist-types/consent-banner.d.ts",
			"import": "./dist/consent-banner.js",
			"require": "./dist/consent-banner.cjs"
		},
		"./consent-dialog": {
			"types": "./dist-types/consent-dialog.d.ts",
			"import": "./dist/consent-dialog.js",
			"require": "./dist/consent-dialog.cjs"
		},
		"./consent-widget": {
			"types": "./dist-types/consent-widget.d.ts",
			"import": "./dist/consent-widget.js",
			"require": "./dist/consent-widget.cjs"
		},
		"./consent-dialog-link": {
			"types": "./dist-types/consent-dialog-link.d.ts",
			"import": "./dist/consent-dialog-link.js",
			"require": "./dist/consent-dialog-link.cjs"
		},
		"./consent-dialog-trigger": {
			"types": "./dist-types/consent-dialog-trigger.d.ts",
			"import": "./dist/consent-dialog-trigger.js",
			"require": "./dist/consent-dialog-trigger.cjs"
		},
		"./frame": {
			"types": "./dist-types/frame.d.ts",
			"import": "./dist/frame.js",
			"require": "./dist/frame.cjs"
		},
		"./iab": {
			"types": "./dist-types/iab.d.ts",
			"import": "./dist/iab.js",
			"require": "./dist/iab.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist-types/index.d.ts",
	"files": [
		"dist",
		"dist-types",
		"client",
		"styles.css",
		"styles.tw3.css",
		"iab",
		"src/styles.tw3.css",
		"src/iab/styles.tw3.css",
		"!dist/mockServiceWorker.js"
	],
	"scripts": {
		"prebuild": "genversion --esm --semi src/version.ts",
		"build": "bun prebuild && rslib build && bun ../../scripts/normalize-dist-types.mjs && bun run clean:dist:test-artifacts",
		"check-types": "bun prebuild && tsc --noEmit",
		"clean:dist:test-artifacts": "bun --eval \"import { rmSync } from 'node:fs'; rmSync('dist/mockServiceWorker.js', { force: true });\"",
		"dev": "sh -c 'bun prebuild && rslib build --no-dts --no-clean && rslib build --watch --no-dts --no-clean'",
		"fmt": "bun biome format --write . && bun biome check --formatter-enabled=false --linter-enabled=false --write",
		"lint": "bun biome lint ./src",
		"prepack": "bun run build",
		"test": "bun prebuild && vitest run",
		"test:watch": "bun prebuild && vitest"
	},
	"browserslist": [
		">0.2%",
		"not dead",
		"not op_mini all"
	],
	"dependencies": {
		"@c15t/iab-v3": "workspace:*",
		"@c15t/ui": "workspace:*",
		"c15t-v3": "workspace:*",
		"c15t": "workspace:*"
	},
	"devDependencies": {
		"@c15t/backend": "workspace:*",
		"@c15t/conformance": "workspace:*",
		"@c15t/typescript-config": "workspace:*",
		"@c15t/vitest-config": "workspace:*",
		"@iabtechlabtcf/core": "^1.5.20",
		"genversion": "3.2.0",
		"msw": "^2.12.14",
		"@c15t/iab": "workspace:*"
	},
	"peerDependencies": {
		"react": "^19.0.0 || ^19.0.0-rc || ^18.0.0 || ^17.0.0 || ^16.8.0",
		"react-dom": "^19.0.0 || ^19.0.0-rc || ^18.0.0 || ^17.0.0 || ^16.8.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	}
}
