{
	"extends": "@c15t/typescript-config/react-library.json",
	"compilerOptions": {
		"rootDir": "src",
		"moduleResolution": "bundler",
		"types": ["@vitest/browser/matchers"],
		"paths": {
			"@c15t/ui/styles/primitives": [
				"../ui/dist-types/styles/primitives/index.d.ts"
			],
			"@c15t/ui/styles/primitives/*": [
				"../ui/dist-types/styles/primitives/*.d.ts"
			],
			"@c15t/ui/primitives": ["../ui/dist-types/primitives/index.d.ts"],
			"@c15t/ui/primitives/data-state": [
				"../ui/dist-types/primitives/data-state.d.ts"
			],
			"@c15t/ui/primitives/*": [
				"../ui/dist-types/primitives/*/index.d.ts",
				"../ui/dist-types/primitives/*.d.ts"
			],
			"@c15t/ui/theme": ["../ui/dist-types/theme/index.d.ts"],
			"@c15t/ui/utils": ["../ui/dist-types/utils/index.d.ts"],
			"c15t": ["../core/dist-types/index.d.ts"],
			"c15t/*": ["../core/dist-types/*"],
			"~/*": ["./src/*"],
			"@c15t/react-v3": ["../react-v3/dist-types/index.d.ts"],
			"@c15t/react-v3/*": ["../react-v3/dist-types/*"],
			"c15t-v3": ["../core-v3/dist-types/index.d.ts"],
			"c15t-v3/*": ["../core-v3/dist-types/*"],
			"@c15t/iab-v3": ["../iab-v3/dist-types/index.d.ts"],
			"@c15t/iab-v3/*": ["../iab-v3/dist-types/*"],
			"@c15t/react-v3/hooks": ["../react-v3/dist-types/v3/hooks.d.ts"]
		}
	},
	"include": ["src"],
	"exclude": [
		"node_modules",
		"src/**/__tests__/**",
		"src/**/__snapshots__/**",
		"src/**/__screenshots__/**",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx",
		"src/**/*.e2e.ts",
		"src/**/*.e2e.test.ts",
		"src/**/*.e2e.test.tsx",
		"src/**/mockServiceWorker.js",
		"src/**/test-setup.*"
	]
}
