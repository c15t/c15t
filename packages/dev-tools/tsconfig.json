{
	"extends": "@c15t/typescript-config/react-library.json",
	"compilerOptions": {
		"baseUrl": ".",
		"lib": ["dom", "dom.iterable", "esnext"],
		"paths": {
			"@c15t/ui/theme": ["../ui/dist-types/theme/index.d.ts"],
			"@c15t/ui/utils": ["../ui/dist-types/utils/index.d.ts"],
			"c15t": ["../core/dist-types/index.d.ts"],
			"c15t/*": ["../core/dist-types/*"],
			"~/*": ["./src/*"]
		}
	},
	"include": ["src"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/__tests__/**",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx"
	]
}
