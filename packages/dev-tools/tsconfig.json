{
	"extends": "@c15t/typescript-config/react-library.json",
	"compilerOptions": {
		"baseUrl": ".",
		"lib": ["dom", "dom.iterable", "esnext"],
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": ["src"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/__tests__/**",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/**/*.spec.ts",
		"src/**/*.spec.tsx"
	]
}
