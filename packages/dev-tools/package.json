{
	"name": "@c15t/dev-tools",
	"version": "1.8.3",
	"description": "Developer tools for debugging and inspecting c15t consent management state.",
	"homepage": "https://c15t.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/c15t/c15t.git",
		"directory": "packages/dev-tools"
	},
	"license": "GPL-3.0-only",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"types": "./dist/index.d.ts"
		},
		"./react": {
			"import": "./dist/react.js",
			"require": "./dist/react.cjs",
			"types": "./dist/react.d.ts"
		},
		"./tanstack": {
			"import": "./dist/tanstack.js",
			"require": "./dist/tanstack.cjs",
			"types": "./dist/tanstack.d.ts"
		}
	},
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "rslib build",
		"check-types": "tsc --noEmit",
		"dev": "rslib build --watch",
		"fmt": "bun biome format --write . && bun biome check --formatter-enabled=false --linter-enabled=false --write",
		"lint": "bun biome lint ./src"
	},
	"browserslist": [
		">0.2%",
		"not dead",
		"not op_mini all"
	],
	"dependencies": {
		"@c15t/ui": "workspace:*",
		"c15t": "workspace:*"
	},
	"devDependencies": {
		"@c15t/typescript-config": "workspace:*",
		"@types/react": "19.2.10",
		"@types/react-dom": "19.2.3",
		"postcss": "8.5.6"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	}
}
