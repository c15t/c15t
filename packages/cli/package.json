{
	"name": "@c15t/cli",
	"version": "2.1.0",
	"description": "CLI for rapid c15t setup. Scaffold React and Next.js cookie banners and a preference center, generate types and config, and run migration tooling for self-hosted deployments.",
	"keywords": [
		"c15t",
		"cli",
		"consent",
		"privacy",
		"gdpr",
		"ccpa",
		"lgpd",
		"tcf",
		"cmp",
		"cookie-banner",
		"cookie-consent",
		"consent-management",
		"scaffold",
		"codegen",
		"migrations",
		"codemod",
		"nextjs",
		"react",
		"typescript"
	],
	"homepage": "https://c15t.com/docs/cli/overview",
	"bugs": {
		"url": "https://github.com/c15t/c15t/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/c15t/c15t.git",
		"directory": "packages/cli"
	},
	"license": "Apache-2.0",
	"type": "module",
	"exports": "./dist/index.mjs",
	"main": "./dist/index.mjs",
	"module": "dist/index.mjs",
	"types": "./dist-types/index.d.ts",
	"bin": {
		"cli": "dist/index.mjs"
	},
	"files": [
		"dist",
		"dist-types",
		"AGENTS.md",
		"docs"
	],
	"scripts": {
		"build": "rslib build && bun ../../scripts/normalize-dist-types.mjs && bun ../../scripts/generate-package-docs.ts @c15t/cli",
		"build:docs": "bun ../../scripts/generate-package-docs.ts @c15t/cli",
		"check-types": "tsc --noEmit",
		"dev": "sh -c 'rslib build --no-dts --no-clean && rslib build --watch --no-dts --no-clean'",
		"fmt": "bun biome format --write . && bun biome check --formatter-enabled=false --linter-enabled=false --write",
		"knip": "knip",
		"lint": "bun biome lint ./src",
		"start": "node ./dist/index.mjs",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@c15t/backend": "workspace:*",
		"@c15t/logger": "workspace:*",
		"@c15t/scripts": "workspace:*",
		"@clack/prompts": "1.4.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"c12": "3.3.4",
		"dotenv": "17.4.2",
		"evlog": "^2.17.0",
		"figlet": "1.11.0",
		"fs-extra": "11.3.5",
		"open": "11.0.0",
		"package-manager-detector": "1.6.0",
		"picocolors": "1.1.1",
		"ts-morph": "28.0.0",
		"xstate": "^5.31.1",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@c15t/typescript-config": "workspace:*",
		"@c15t/vitest-config": "workspace:*",
		"@types/figlet": "1.7.0",
		"@types/fs-extra": "11.0.4",
		"@types/prettier": "^3.0.0",
		"prettier": "^3.8.3"
	},
	"publishConfig": {
		"access": "public",
		"executableFiles": [
			"./dist/index.mjs"
		]
	}
}
