{
	"name": "c15t-v3",
	"version": "2.0.0",
	"description": "Temporary v3 kernel package for c15t.",
	"keywords": [
		"consent",
		"privacy",
		"gdpr",
		"cmp",
		"v3"
	],
	"homepage": "https://c15t.com/docs/frameworks/javascript/quickstart",
	"repository": {
		"type": "git",
		"url": "https://github.com/c15t/c15t.git",
		"directory": "packages/core-v3"
	},
	"license": "Apache-2.0",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist-types/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./modules/script-loader": {
			"types": "./dist-types/modules/script-loader/index.d.ts",
			"import": "./dist/script-loader.js",
			"require": "./dist/script-loader.cjs"
		},
		"./modules/network-blocker": {
			"types": "./dist-types/modules/network-blocker/index.d.ts",
			"import": "./dist/network-blocker.js",
			"require": "./dist/network-blocker.cjs"
		},
		"./modules/iframe-blocker": {
			"types": "./dist-types/modules/iframe-blocker/index.d.ts",
			"import": "./dist/iframe-blocker.js",
			"require": "./dist/iframe-blocker.cjs"
		},
		"./modules/persistence": {
			"types": "./dist-types/modules/persistence/index.d.ts",
			"import": "./dist/persistence.js",
			"require": "./dist/persistence.cjs"
		}
	},
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "./dist-types/index.d.ts",
	"files": [
		"dist",
		"dist-types"
	],
	"scripts": {
		"prebuild": "genversion --esm --semi src/version.ts",
		"build": "bun prebuild && rslib build && bun ../../scripts/normalize-dist-types.mjs",
		"check-types": "bun prebuild && tsc --noEmit",
		"dev": "sh -c 'bun prebuild && rslib build --no-dts --no-clean && rslib build --watch --no-dts --no-clean'",
		"fmt": "bun biome format --write . && bun biome check --formatter-enabled=false --linter-enabled=false --write",
		"lint": "bun biome lint ./src",
		"prepack": "bun run build",
		"test": "bun prebuild && vitest run",
		"test:watch": "bun prebuild && vitest"
	},
	"dependencies": {
		"@c15t/schema": "workspace:*",
		"@c15t/translations": "workspace:*"
	},
	"devDependencies": {
		"@c15t/typescript-config": "workspace:*",
		"@c15t/vitest-config": "workspace:*",
		"genversion": "3.2.0",
		"vitest-localstorage-mock": "0.1.2"
	},
	"publishConfig": {
		"access": "public"
	}
}
