{
	"name": "c15t-workspace",
	"private": true,
	"description": "Developer-first Consent Management Platform",
	"homepage": "https://c15t.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/c15t/c15t.git"
	},
	"license": "GPL-3.0-only",
	"type": "module",
	"workspaces": [
		"benchmarks/**",
		"apps/*",
		"configs/*",
		"packages/**",
		"internals/**",
		"examples/demo"
	],
	"scripts": {
		"bench": "turbo run bench --filter=@c15t/core-benchmarks --filter=@c15t/next-bundle-bench --filter=@c15t/react-browser-bench --filter=@c15t/nextjs-browser-bench --filter=@c15t/script-lifecycle-bench",
		"bench:ci": "turbo run bench:ci --filter=@c15t/core-benchmarks --filter=@c15t/next-bundle-bench --filter=@c15t/react-browser-bench --filter=@c15t/nextjs-browser-bench --filter=@c15t/script-lifecycle-bench",
		"bench:compare": "bunx tsx benchmarks/shared/run-compare.ts",
		"bench:nightly": "turbo run bench:nightly --filter=@c15t/core-benchmarks --filter=@c15t/next-bundle-bench --filter=@c15t/react-browser-bench --filter=@c15t/nextjs-browser-bench --filter=@c15t/script-lifecycle-bench",
		"build": "turbo run build",
		"build:libs": "turbo run build --filter=./packages/**",
		"changeset": "changeset",
		"check:publish-artifacts": "bun scripts/check-publish-artifacts.ts",
		"check-types": "turbo run check-types",
		"ci:publish": "bunx changeset tag && bun publish",
		"ci:version": "bun changeset version",
		"clear-cache": "bun scripts/clear-rslib-cache.ts",
		"css-layer:build": "turbo run build --filter=@c15t/css-layer-preview --filter=@c15t/tw3-css-test --filter=@c15t/tw4-css-test --filter=@c15t/no-tw-css-test",
		"css-layer:dev": "turbo run dev --only --filter=@c15t/css-layer-preview --filter=@c15t/tw3-css-test --filter=@c15t/tw4-css-test --filter=@c15t/no-tw-css-test",
		"css-layer:review": "node scripts/css-layer-review.mjs",
		"dev": "turbo watch dev --concurrency=15 --filter=!./examples/** --filter=!./benchmarks/** --filter=!./apps/**",
		"fmt": "turbo run fmt",
		"fmt:docs": "bunx remark ./docs --ext mdx --output --use remark-mdx --use remark-frontmatter --use remark-preset-lint-recommended --use remark-preset-lint-consistent",
		"generate:readmes": "tsx scripts/generate-readme.ts",
		"postinstall": "lefthook install",
		"knip": "knip",
		"lint": "turbo run lint",
		"lint:docs": "bunx remark ./docs --ext mdx --output --use remark-mdx --use remark-frontmatter --use remark-preset-lint-recommended --use remark-preset-lint-consistent",
		"lint:fix": "turbo run lint -- --write",
		"release": "bun run build && bun run check:publish-artifacts && bun scripts/resolve-workspace-deps.ts && changeset publish",
		"release:canary": "bun run build && bun run check:publish-artifacts && bun scripts/resolve-workspace-deps.ts && changeset publish --tag canary",
		"release:rc": "bun run build:libs && bun run check:publish-artifacts && bun scripts/resolve-workspace-deps.ts && changeset publish",
		"setup:docs": "tsx scripts/setup-docs.ts",
		"test": "turbo run test",
		"vercel-build": "tsx scripts/setup-docs.ts --vercel",
		"version": "changeset version && bun install",
		"version:canary": "changeset version --snapshot canary && bun install",
		"version:rc": "changeset pre enter rc",
		"version:rc:exit": "changeset pre exit",
		"view-report": "turbo run view-report"
	},
	"overrides": {
		"cross-spawn": ">=6.0.6",
		"typeorm": ">=0.3.26"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@changesets/changelog-github": "0.6.0",
		"@changesets/cli": "2.30.0",
		"@rsbuild/core": "1.7.5",
		"@rsbuild/plugin-react": "1.4.6",
		"@rsdoctor/rspack-plugin": "1.5.7",
		"@rslib/core": "0.20.2",
		"@rspack/resolver-binding-wasm32-wasi": "0.2.8",
		"@types/bun": "latest",
		"@types/mdast": "4.0.4",
		"@types/node": "25.5.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"@vitest/browser": "4.1.2",
		"@vitest/browser-playwright": "4.1.2",
		"@vitest/coverage-istanbul": "4.1.2",
		"@vitest/coverage-v8": "4.1.2",
		"baseline-browser-mapping": "latest",
		"changeset-conventional-commits": "1.0.3",
		"decode-named-character-reference": "1.3.0",
		"fast-glob": "3.3.3",
		"json5": "2.2.3",
		"knip": "6.1.1",
		"lefthook": "2.1.4",
		"mdast-util-compact": "5.0.0",
		"mdast-util-mdx": "3.0.0",
		"mdast-util-mdx-jsx": "3.2.0",
		"mdast-util-mdxjs-esm": "2.0.1",
		"mdast-util-to-markdown": "2.1.2",
		"mdast-util-to-string": "4.0.0",
		"playwright": "1.58.2",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"remark": "15.0.1",
		"remark-cli": "12.0.1",
		"remark-frontmatter": "5.0.0",
		"remark-gfm": "4.0.1",
		"remark-mdx": "3.1.1",
		"remark-preset-lint-consistent": "6.0.1",
		"remark-preset-lint-recommended": "7.0.1",
		"tsx": "4.21.0",
		"turbo": "2.9.1",
		"typescript": "6.0.2",
		"unified": "11.0.5",
		"unist-builder": "4.0.0",
		"unist-util-is": "6.0.1",
		"unist-util-visit": "5.1.0",
		"vite": "8.0.3",
		"vitest": "4.1.2",
		"vitest-browser-react": "2.1.0"
	},
	"packageManager": "bun@1.3.11",
	"engines": {
		"node": ">=18.17.0"
	}
}
