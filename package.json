{
	"name": "c15t",
	"private": true,
	"description": "Developer-first Consent Management Platform",
	"homepage": "https://c15t.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/c15t/c15t.git"
	},
	"license": "GPL-3.0-only",
	"type": "module",
	"workspaces": [
		"configs/*",
		"packages/**",
		"internals/**"
	],
	"scripts": {
		"build": "turbo build",
		"build:libs": "turbo build --filter=./packages/**",
		"changeset": "changeset",
		"check-types": "turbo check-types",
		"ci:publish": "bunx changeset tag && bun publish",
		"ci:version": "bun changeset version",
		"dev": "turbo dev --concurrency=15 --filter=!./examples/**",
		"fmt": "turbo fmt",
		"fmt:docs": "bunx remark ./docs --ext mdx --output --use remark-mdx --use remark-frontmatter --use remark-preset-lint-recommended --use remark-preset-lint-consistent",
		"generate:readmes": "tsx scripts/generate-readme.ts",
		"postinstall": "lefthook install",
		"knip": "knip",
		"lint": "turbo lint",
		"lint:docs": "bunx remark ./docs --ext mdx --output --use remark-mdx --use remark-frontmatter --use remark-preset-lint-recommended --use remark-preset-lint-consistent",
		"lint:fix": "turbo lint -- --write",
		"release": "bun run build && bun run resolve-workspace-deps && changeset publish",
		"release:canary": "bun run build && bun run resolve-workspace-deps && changeset publish --tag canary",
		"release:rc": "bun run build && bun run resolve-workspace-deps && changeset publish",
		"resolve-workspace-deps": "tsx scripts/resolve-workspace-deps.ts",
		"setup:docs": "tsx scripts/setup-docs.ts",
		"test": "turbo test",
		"vercel-build": "tsx scripts/setup-docs.ts --vercel",
		"version": "changeset version && bun install",
		"version:canary": "changeset version --snapshot canary && bun install",
		"version:prerelease": "changeset pre enter canary",
		"version:prerelease:exit": "changeset pre exit",
		"view-report": "turbo run view-report"
	},
	"overrides": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"ajv": "^8.18.0",
		"body-parser": "^2.2.2",
		"cross-spawn": ">=6.0.6",
		"diff": "^8.0.3",
		"fast-xml-parser": "^5.5.3",
		"glob": "^13.0.6",
		"immutable": "^5.1.5",
		"js-yaml": "3.14.2",
		"lodash": "^4.17.23",
		"mdast-util-to-hast": "^13.2.1",
		"minimatch": "^10.2.4",
		"qs": "^6.15.0",
		"rollup": "^4.59.0",
		"tmp": "^0.2.5",
		"typeorm": ">=0.3.26",
		"undici": "^6.23.0",
		"vite": "7.1.11"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.7",
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.29.8",
		"@rsbuild/core": "1.6.15",
		"@rsbuild/plugin-react": "^1.4.6",
		"@rsdoctor/rspack-plugin": "^1.3.16",
		"@rslib/core": "^0.17.2",
		"@types/bun": "latest",
		"@types/node": "22.14.1",
		"@types/react": "19.2.0",
		"@types/react-dom": "19.2.0",
		"@vitejs/plugin-react": "^5.1.4",
		"@vitest/browser": "^4.0.18",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/coverage-istanbul": "^4.0.18",
		"changeset-conventional-commits": "^0.2.5",
		"knip": "^5.50.5",
		"lefthook": "^1.11.16",
		"next": "16.1.6",
		"playwright": "^1.56.1",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"remark-cli": "^12.0.1",
		"remark-frontmatter": "^5.0.0",
		"remark-mdx": "^3.1.1",
		"remark-preset-lint-consistent": "^6.0.1",
		"remark-preset-lint-recommended": "^7.0.1",
		"tsx": "^4.19.4",
		"turbo": "^2.5.8",
		"typescript": "5.8.3",
		"vitest": "^4.0.18",
		"vitest-browser-react": "^1.0.1"
	},
	"packageManager": "bun@1.3.10",
	"engines": {
		"node": ">=18.17.0"
	}
}
