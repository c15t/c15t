		"svelte": "^5.55.5"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@storybook/addon-a11y": "10.3.6",
		"@storybook/test-runner": "^0.24.3",
		"@storybook/svelte-vite": "10.3.6",
		"storybook": "10.3.6",
		"typescript": "6.0.3",
		"vite": "8.0.12"
	}
}
